{
  "framework": "nextjs",
  "rewrites": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "hysky.news" }],
      "destination": "/news/:path*"
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.hysky.news" }],
      "destination": "/news/:path*"
    }
  ]
}